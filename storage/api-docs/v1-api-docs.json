        "/api/v1/wallet/redeem-coupon": {
            "post": {
                "tags": [
                    "Portefeuille"
                ],
                "summary": "Utiliser un coupon pour obtenir des crédits",
                "operationId": "ceb997728c79c6fb614e52269848c68f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "code"
                                ],
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "example": "MONCOUPON"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Coupon validé avec succès"
